# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram User ID (get it from @userinfobot)
ADMIN_CHAT_ID=123456789

# Google Gemini API Key (from https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Webhook URL for production (leave empty for polling/dev mode)
# Example: https://your-app.railway.app
WEBHOOK_URL=

# Optional: Redis URL for persistent FSM storage and scaling
# Example: redis://localhost:6379/0
REDIS_URL=

# Path to SQLite database file
DATABASE_PATH=shop.db

# Your PayPal.me link for payments
PAYPAL_LINK=https://paypal.me/yourname

# External URL to your full product collection (optional)
SHOP_COLLECTION_URL=https://your-shop.com/collection

# Shop name displayed in bot messages
SHOP_NAME=My Awesome Shop
